{
  "name": "Cart Total Update",
  "metadata": {
    "business_goal": "Verify that cart total updates correctly when items are added and removed"
  },
  "preconditions": [
    "User is logged in to the app",
    "Cart is empty at test start",
    "At least one product is available in the catalog"
  ],
  "test_data": {
    "item_price": {"value": 9.99, "stable": true},
    "item_name": {"value": "Milk 3%", "stable": true},
    "second_item_price": {"value": 4.50, "stable": true}
  },
  "steps": [
    {
      "action": "Navigate to product catalog",
      "expected_result": "Product list is displayed",
      "validation_method": "Verify Content"
    },
    {
      "action": "Add first item to cart",
      "expected_result": "Cart badge shows count of 1",
      "validation_method": "Verify Count"
    },
    {
      "action": "Add second item to cart",
      "expected_result": "Cart badge shows count of 2",
      "validation_method": "Verify Count"
    },
    {
      "action": "Open cart and check total",
      "expected_result": "Total equals sum of both item prices",
      "validation_method": "Verify Content"
    }
  ],
  "results": [
    {"classification": "PASS", "label": "Cart count increments correctly"},
    {"classification": "FAIL", "label": "Total is wrong or missing"},
    {"classification": "WARN", "label": "Total is shown but rounding differs"}
  ],
  "automation_readiness_status": "ready_for_automation",
  "risks": [
    {"risk": "Price data in catalog may change between runs", "mitigation": "Use fixed test data from fixtures"}
  ],
  "registry_needs": []
}
