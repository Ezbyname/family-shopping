{
  "name": "family-shopping-tests",
  "version": "1.0.0",
  "private": true,
  "description": "E2E + smoke tests for Family Shopping PWA",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:smoke": "node smoke/firebase-health.js",
    "test:smoke:vercel": "node smoke/vercel-health.js",
    "test:all": "npm run test:smoke && npm run test:e2e",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@playwright/test": "1.60.0",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
