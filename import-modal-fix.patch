From 9d9bb1b9aa2b276ab9c1ac9c11a9fa4709ea3483 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sat, 6 Jun 2026 10:53:42 +0000
Subject: [PATCH 1/2] fix(import): split grouped CSS rule so preview-view stays
 hidden on open

---
 styles.css | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/styles.css b/styles.css
index 87cc091..0c9f271 100644
--- a/styles.css
+++ b/styles.css
@@ -1781,8 +1781,8 @@ body.sheet-open{overflow:hidden!important;touch-action:none!important}
   color:var(--text);font-family:'Rubik',sans-serif;font-size:14px;
   outline:none;resize:none;direction:rtl;}
 .import-textarea:focus{border-color:var(--accent)}
-.import-textarea-view,.import-preview-view{display:flex;flex-direction:column;gap:10px;flex:1}
-.import-preview-view{display:none}
+.import-textarea-view{display:flex;flex-direction:column;gap:10px;flex:1}
+.import-preview-view{display:none;flex-direction:column;gap:10px;flex:1}
 .import-preview-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;min-height:80px;max-height:220px}
 .import-preview-row{display:flex;align-items:center;gap:8px;padding:7px 10px;
   background:var(--card);border-radius:10px;font-size:14px}
-- 
2.43.0


From 9f1562a4187f5530aa5cbf7faf12dc8644d0fe8d Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sat, 6 Jun 2026 10:54:14 +0000
Subject: [PATCH 2/2] fix(import): full-screen overlay with X close button,
 slide-up animation

---
 index.html |  8 +++++---
 styles.css | 20 +++++++++++++-------
 2 files changed, 18 insertions(+), 10 deletions(-)

diff --git a/index.html b/index.html
index 21807db..2852733 100644
--- a/index.html
+++ b/index.html
@@ -873,10 +873,12 @@
 </div>
 
 <!-- import modal -->
-<div class="import-overlay" id="import-overlay" onclick="if(event.target===this)closeImportModal()">
+<div class="import-overlay" id="import-overlay">
   <div class="import-modal">
-    <div class="modal-handle"></div>
-    <div class="modal-title">📋 ייבוא רשימה</div>
+    <div class="import-modal-header">
+      <button class="import-close-btn" onclick="closeImportModal()" aria-label="סגור">✕</button>
+      <div class="modal-title" style="margin:0">📋 ייבוא רשימה</div>
+    </div>
     <div class="import-textarea-view" id="import-textarea-view">
       <div style="font-size:12px;color:var(--muted);margin-top:-4px">
         הדבק רשימה מוואטסאפ או SMS — שורה אחת לכל פריט.<br>
diff --git a/styles.css b/styles.css
index 0c9f271..f63501e 100644
--- a/styles.css
+++ b/styles.css
@@ -1771,19 +1771,25 @@ body.sheet-open{overflow:hidden!important;touch-action:none!important}
   display:flex;align-items:center;justify-content:center;flex-shrink:0;
   transition:opacity .1s;}
 .import-btn:active{opacity:.7}
-.import-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);
-  z-index:1100;align-items:flex-end;justify-content:center;}
-.import-modal{background:var(--surface);border-radius:20px 20px 0 0;
-  padding:16px 18px calc(24px + var(--safe-b));width:100%;max-width:520px;
-  max-height:70vh;display:flex;flex-direction:column;gap:10px;}
-.import-textarea{flex:1;min-height:140px;background:var(--card);
+.import-overlay{display:none;position:fixed;inset:0;z-index:1100;
+  align-items:flex-end;justify-content:center;}
+.import-modal{background:var(--surface);
+  padding:16px 18px calc(24px + var(--safe-b));width:100%;
+  height:100%;display:flex;flex-direction:column;gap:10px;
+  animation:importSlideUp .22s cubic-bezier(.25,.8,.25,1) both;}
+@keyframes importSlideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
+.import-modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2px}
+.import-close-btn{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted);
+  padding:4px 6px;border-radius:8px;line-height:1;transition:opacity .1s;}
+.import-close-btn:active{opacity:.5}
+.import-textarea{flex:1;min-height:200px;background:var(--card);
   border:1.5px solid var(--border);border-radius:12px;padding:10px 12px;
   color:var(--text);font-family:'Rubik',sans-serif;font-size:14px;
   outline:none;resize:none;direction:rtl;}
 .import-textarea:focus{border-color:var(--accent)}
 .import-textarea-view{display:flex;flex-direction:column;gap:10px;flex:1}
 .import-preview-view{display:none;flex-direction:column;gap:10px;flex:1}
-.import-preview-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;min-height:80px;max-height:220px}
+.import-preview-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;min-height:80px}
 .import-preview-row{display:flex;align-items:center;gap:8px;padding:7px 10px;
   background:var(--card);border-radius:10px;font-size:14px}
 .import-preview-missing{opacity:.5}
-- 
